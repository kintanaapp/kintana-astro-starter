---
import Base from "../layouts/Base.astro";
import { kintanaClient } from "../lib/kintana";

let gallery: Awaited<ReturnType<ReturnType<typeof kintanaClient>["getSiteGallery"]>> = [];
try {
  gallery = await kintanaClient().getSiteGallery();
} catch {
  gallery = [];
}
---

<Base title="Gallery">
  <h1 class="text-2xl font-semibold">Gallery</h1>
  {gallery.length === 0 ? (
    <p class="mt-4 text-sm text-neutral-500">No photos yet — add some in Kintana → Websites → Custom site.</p>
  ) : (
    <ul class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3">
      {gallery.map((item) => (
        <li>
          <img
            src={item.url}
            alt={item.alt ?? ""}
            class="aspect-square w-full rounded-lg object-cover"
            loading="lazy"
          />
          {item.caption ? (
            <p class="mt-2 text-xs text-neutral-600 dark:text-neutral-400">{item.caption}</p>
          ) : null}
        </li>
      ))}
    </ul>
  )}
</Base>
