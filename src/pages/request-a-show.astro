---
import Base from "../layouts/Base.astro";
import { RequestShowIsland } from "../components/RequestShowIsland";

const apiKey = import.meta.env.PUBLIC_KINTANA_API_KEY;
const baseUrl = import.meta.env.PUBLIC_KINTANA_BASE_URL;
const formId = import.meta.env.PUBLIC_KINTANA_SHOW_REQUEST_FORM_ID?.trim();
---

<Base>
  <h1 class="text-2xl font-semibold tracking-tight">Request a show</h1>
  <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
    We hydrate a tiny React island so validations match the upstream embed implementation.
  </p>

  {
    apiKey && baseUrl && formId ? (
      <div class="mt-10 max-w-xl">
        <RequestShowIsland client:load apiKey={apiKey} baseUrl={baseUrl} formId={formId} />
      </div>
    ) : (
      <p class="mt-10 rounded-lg border border-amber-300 bg-amber-50 p-4 text-sm text-amber-950 dark:border-amber-900 dark:bg-amber-950/40 dark:text-amber-100">
        Populate <span class="font-mono text-xs">PUBLIC_KINTANA_API_KEY</span>,{" "}
        <span class="font-mono text-xs">PUBLIC_KINTANA_BASE_URL</span>, and{" "}
        <span class="font-mono text-xs">PUBLIC_KINTANA_SHOW_REQUEST_FORM_ID</span> before relying on this
        page.
      </p>
    )
  }
</Base>
