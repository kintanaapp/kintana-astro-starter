---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Kintana starter site" }: Props = Astro.props;

function escapeAttr(v: string) {
  return v.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

const TRACK_BASE = import.meta.env.PUBLIC_KINTANA_BASE_URL?.replace(/\/$/, "") ?? "";
const TRACK_KEY = import.meta.env.PUBLIC_KINTANA_API_KEY ?? "";
const trackerMarkup =
  TRACK_BASE && TRACK_KEY
    ? `<script async src="${escapeAttr(TRACK_BASE)}/_t/k.js" data-token="${escapeAttr(
        TRACK_KEY
      )}" data-api-base="${escapeAttr(TRACK_BASE)}"><\\/script>`
    : "";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-white px-4 py-10 text-neutral-900 antialiased dark:bg-neutral-950 dark:text-neutral-50">
    <header class="mb-12 flex gap-8 border-b border-neutral-200 pb-4 dark:border-neutral-800">
      <a class="text-sm font-semibold text-[#e35336]" href="/">Shows</a>
      <a class="text-sm font-semibold text-[#e35336]" href="/request-a-show/">Request</a>
    </header>

    <main class="mx-auto max-w-3xl">
      <slot />
    </main>

    {trackerMarkup ? <span aria-hidden="true" class="hidden" set:html={trackerMarkup} /> : null}
  </body>
</html>
